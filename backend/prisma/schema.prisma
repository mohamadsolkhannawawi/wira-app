generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String          @id @default(uuid())
  email      String          @unique
  username   String          @unique
  password   String
  name       String?
  role       UserRole        @default(USER)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  analyses   AnalysisHistory[]
  tokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model StreetLocation {
  id          String   @id @default(uuid())
  namaJalan   String
  kelurahan   String
  kecamatan   String
  latCentroid Float
  lngCentroid Float

  analyses    AnalysisHistory[]

  @@unique([namaJalan, kelurahan])
  @@index([kelurahan])
  @@index([kecamatan])
  @@map("street_locations")
}

model AnalysisHistory {
  id                String       @id @default(uuid())
  streetName        String
  kelurahan         String
  kecamatan         String
  bizType           BusinessType

  skorPotensi       Float
  trafficScore      Float
  transitScore      Float
  poiScore          Float
  competitor        Float
  compRatio         Float

  bobotTraffic      Float
  bobotTransit      Float
  bobotPoi          Float
  bobotCompetitor   Float
  bobotCompRatio    Float

  rekomendasiAlternatif Json?
  aiInsight         String?      @db.Text

  userId            String?
  isSaved           Boolean      @default(false)

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user   User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  street StreetLocation? @relation(fields: [streetName, kelurahan], references: [namaJalan, kelurahan])

  @@index([userId])
  @@index([bizType])
  @@index([kelurahan])
  @@index([createdAt])
  @@map("analysis_histories")
}

enum UserRole {
  USER
  ADMIN
}

enum BusinessType {
  CAFE
  LAUNDRY
  FNB
  BARBERSHOP
  SALON
  GYM
  BENGKEL
  CARWASH
  FASHION
  ELEKTRONIK
  PHOTOSTUDIO
  STATIONERY
}
