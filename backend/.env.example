NODE_ENV=development
APP_NAME=WIRA API
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wira

# JWT
JWT_SECRET=change-this-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# AI Model Service
AI_RECOMMEND_URL=http://[IP_ADDRESS]

# Gemini
GEMINI_API_KEY=change-this-api-key
GEMINI_BACKUP_API_KEY=optional-backup-gemini-key
GROQ_API_KEY=optional-groq-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
